// Swifty Agent Configuration Reference
// The Go version loads configuration from config.json (not environment variables).
// This file mirrors the Next.js .env.example, listing the corresponding config.json
// fields and their defaults to facilitate migration from Next.js or to quickly
// identify which fields need to be configured. The KEY=VALUE pairs below are
// illustrative only — edit config.json for actual configuration.

{
  // ---- Server ----
  "server_addr": ":8123",
  // ---- LLM Provider ----
  "model_provider": "openai", // "openai" | "anthropic"
  // ---- Think Model (planning/replan) ----
  "think_chat_model": {
    "api_key": "your-api-key",
    // Anthropic: SDK auto-appends /v1/messages, so base_url should NOT include /v1
    // OpenAI: base_url is used as-is, typically includes /v1
    "base_url": "https://ark.cn-beijing.volces.com/api",
    "model": "deepseek-v3-2-251201",
    "max_tokens": 4096,
    // Anthropic extended thinking (only effective when model_provider=anthropic)
    "thinking": false
  },
  // ---- Quick Model (chat/tool execution) ----
  "quick_chat_model": {
    "api_key": "your-api-key",
    // Anthropic: SDK auto-appends /v1/messages, so base_url should NOT include /v1
    // OpenAI: base_url is used as-is, typically includes /v1
    "base_url": "https://ark.cn-beijing.volces.com/api/v3",
    "model": "deepseek-v3-2-251201",
    "max_tokens": 4096,
    // Anthropic extended thinking (only effective when model_provider=anthropic)
    "thinking": false
  },
  // ---- Embedding ----
  "embedding_model": {
    "provider": "dashscope", // "dashscope" | "ollama"
    "api_key": "your-api-key",
    "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
    "model": "text-embedding-v4",
    "dimensions": 2048,
    "ollama_base_url": "http://localhost:11434",
    "ollama_model": "nomic-embed-text"
  },
  // ---- File Upload Directory ----
  "file_dir": "./data/docs",
  // ---- MCP (Log Tool SSE) ----
  "mcp_url": "http://localhost:3000/sse",
  // ---- Prometheus ----
  // leave empty to disable the query_prometheus_alerts tool
  "prometheus_url": "http://127.0.0.1:9090",
  // injected into chat system prompt; takes effect only when both are non-empty
  "log_topic_region": "",
  "log_topic_id": "",

  // ---- Redis Stack (RediSearch) ----
  "redis": {
    "addr": "localhost:6379",
    "password": "",
    "db": 0
  }
}

// The following are constants (aligned with Next.js); to change them, edit internal/consts/consts.go
// REDIS_INDEX_NAME=idx:biz
// REDIS_KEY_PREFIX=biz:
// REDIS_VECTOR_FIELD=vector
