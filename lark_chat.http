@host = http://localhost:8000

### ===== Auth =====

### Login
POST {{host}}/login
Content-Type: application/json

{
  "telephone": "18012345678",
  "password": "123456"
}

### Register
POST {{host}}/register
Content-Type: application/json

{
  "telephone": "18012345678",
  "password": "123456",
  "nickname": "testuser"
}

### ===== User =====

### Update user info
POST {{host}}/user/update-user-info
Content-Type: application/json

{
  "uuid": "U12345678901",
  "nickname": "Jane Doe",
  "email": "test@example.com",
  "birthday": "19990101",
  "signature": "hello world",
  "avatar": ""
}

### Get user info
POST {{host}}/user/get-user-info
Content-Type: application/json

{
  "uuid": "U12345678901"
}

### Get user info list (admin)
POST {{host}}/user/get-user-info-list
Content-Type: application/json

{
  "owner_id": "U12345678901"
}

### Enable users
POST {{host}}/user/able-users
Content-Type: application/json

{
  "uuid_list": ["U12345678901"]
}

### Disable users
POST {{host}}/user/disable-users
Content-Type: application/json

{
  "uuid_list": ["U12345678901"]
}

### Delete users
POST {{host}}/user/delete-users
Content-Type: application/json

{
  "uuid_list": ["U12345678901"]
}

### Set admin
POST {{host}}/user/set-admin
Content-Type: application/json

{
  "uuid_list": ["U12345678901"],
  "is_admin": 1
}

### WebSocket logout
POST {{host}}/user/ws-logout
Content-Type: application/json

{
  "owner_id": "U12345678901"
}

### ===== Group =====

### Create group
POST {{host}}/group/create-group
Content-Type: application/json

{
  "name": "test group",
  "owner_id": "U12345678901",
  "avatar": ""
}

### Load my groups
POST {{host}}/group/load-my-group
Content-Type: application/json

{
  "owner_id": "U12345678901"
}

### Check group add mode
POST {{host}}/group/check-group-add-mode
Content-Type: application/json

{
  "group_id": "G12345678901"
}

### Enter group directly
POST {{host}}/group/enter-group-directly
Content-Type: application/json

{
  "user_id": "U12345678901",
  "group_id": "G12345678901"
}

### Leave group
POST {{host}}/group/leave-group
Content-Type: application/json

{
  "user_id": "U12345678901",
  "group_id": "G12345678901"
}

### Dismiss group
POST {{host}}/group/dismiss-group
Content-Type: application/json

{
  "group_id": "G12345678901"
}

### Get group info
POST {{host}}/group/get-group-info
Content-Type: application/json

{
  "uuid": "G12345678901"
}

### Update group info
POST {{host}}/group/update-group-info
Content-Type: application/json

{
  "uuid": "G12345678901",
  "name": "new name",
  "notice": "group announcement",
  "avatar": ""
}

### Get group member list
POST {{host}}/group/get-group-member-list
Content-Type: application/json

{
  "group_id": "G12345678901"
}

### Remove group members
POST {{host}}/group/remove-group-members
Content-Type: application/json

{
  "group_id": "G12345678901",
  "member_ids": ["U12345678902"]
}

### Get group info list (admin)
POST {{host}}/group/get-group-info-list
Content-Type: application/json

{}

### Delete groups (admin)
POST {{host}}/group/delete-groups
Content-Type: application/json

{
  "uuid_list": ["G12345678901"]
}

### Set groups status (admin)
POST {{host}}/group/set-groups-status
Content-Type: application/json

{
  "uuid_list": ["G12345678901"],
  "status": 1
}

