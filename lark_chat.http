### ===== Contact =====

### Get contact list
POST {{host}}/contact/get-user-list
Content-Type: application/json

{
  "owner_id": "U12345678901"
}

### Load my joined groups
POST {{host}}/contact/load-my-joined-group
Content-Type: application/json

{
  "owner_id": "U12345678901"
}

### Get contact info
POST {{host}}/contact/get-contact-info
Content-Type: application/json

{
  "user_id": "U12345678901",
  "contact_id": "U12345678902"
}

### Apply contact
POST {{host}}/contact/apply-contact
Content-Type: application/json

{
  "user_id": "U12345678901",
  "contact_id": "U12345678902",
  "contact_type": 0,
  "message": "hi, I am xxx"
}

### Get new contact applications
POST {{host}}/contact/get-new-contact-list
Content-Type: application/json

{
  "user_id": "U12345678901"
}

### Approve contact application
POST {{host}}/contact/pass-contact-apply
Content-Type: application/json

{
  "apply_id": "A12345678901"
}

### Refuse contact application
POST {{host}}/contact/refuse-contact-apply
Content-Type: application/json

{
  "apply_id": "A12345678901"
}

### Block application
POST {{host}}/contact/black-apply
Content-Type: application/json

{
  "apply_id": "A12345678901"
}

### Get add group list
POST {{host}}/contact/get-add-group-list
Content-Type: application/json

{
  "user_id": "U12345678901"
}

### Block contact
POST {{host}}/contact/black-contact
Content-Type: application/json

{
  "user_id": "U12345678901",
  "contact_id": "U12345678902"
}

### Unblock contact
POST {{host}}/contact/cancel-black-contact
Content-Type: application/json

{
  "user_id": "U12345678901",
  "contact_id": "U12345678902"
}

### Delete contact
POST {{host}}/contact/delete-contact
Content-Type: application/json

{
  "user_id": "U12345678901",
  "contact_id": "U12345678902"
}

### ===== Message =====

### Get direct message list
POST {{host}}/message/get-message-list
Content-Type: application/json

{
  "send_id": "U12345678901",
  "receive_id": "U12345678902"
}

### Get group message list
POST {{host}}/message/get-group-message-list
Content-Type: application/json

{
  "group_id": "G12345678901"
}

### Upload avatar (multipart/form-data)
POST {{host}}/message/upload-avatar
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="file"; filename="avatar.png"
Content-Type: image/png

< ./test-avatar.png
--boundary--

### Upload file (multipart/form-data)
POST {{host}}/message/upload-file
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="file"; filename="doc.pdf"
Content-Type: application/pdf

< ./test-doc.pdf
--boundary--

### ===== Chatroom =====

### Get online users
POST {{host}}/chatroom/get-online-users
Content-Type: application/json

{}

### ===== WebSocket =====

### WebSocket connection (use a ws client)
# GET {{host}}/wss?client_id=U12345678901
# Upgrade: websocket
# Connection: Upgrade
