Content-Type: application/json

{
  "send_id": "U12345678901",
  "receive_id": "U12345678902"
}

### Get user session list
POST {{host}}/session/get-user-session-list
Content-Type: application/json

{
  "owner_id": "U12345678901"
}

### Get group session list
POST {{host}}/session/get-group-session-list
Content-Type: application/json

{
  "owner_id": "U12345678901"
}

### Delete session
POST {{host}}/session/delete-session
Content-Type: application/json

{
  "owner_id": "U12345678901",
  "session_id": "S12345678901"
}

### Check open session allowed
POST {{host}}/session/check-open-session-allowed
Content-Type: application/json

{
  "send_id": "U12345678901",
  "receive_id": "U12345678902"
