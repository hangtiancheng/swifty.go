# Swifty Agent 配置说明
#
# Go 版通过 config.json 加载配置(非环境变量)。本文件对照 Next.js 的
# .env.example,列出 config.json 对应字段及其默认值,方便从 Next.js 迁移
# 或快速了解需要配置哪些项。下文 KEY=VALUE 仅作示意,实际请改 config.json。

# ---- 服务 ----
# config.json: server_addr
SERVER_ADDR=:6872

# ---- LLM Provider ----
# config.json: model_provider  ("openai" | "anthropic")
MODEL_PROVIDER=openai

# ---- Think 模型(规划/replan) ----
# config.json: think_chat_model.{api_key,base_url,model,max_tokens,thinking}
THINK_API_KEY=
THINK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
THINK_MODEL=deepseek-v3-2-251201
THINK_MAX_TOKENS=4096
# Anthropic extended thinking (仅 model_provider=anthropic 生效)
THINK_THINKING=false

# ---- Quick 模型(聊天/工具执行) ----
# config.json: quick_chat_model.{api_key,base_url,model,max_tokens,thinking}
QUICK_API_KEY=
QUICK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
QUICK_MODEL=deepseek-v3-2-251201
QUICK_MAX_TOKENS=4096
QUICK_THINKING=false

# ---- Embedding ----
# config.json: embedding_model.provider  ("dashscope" | "ollama")
EMBEDDING_PROVIDER=dashscope
# DashScope (provider=dashscope)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=text-embedding-v4
EMBEDDING_DIM=2048
# Ollama (provider=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text

# ---- Redis Stack (RediSearch) ----
# config.json: redis.{addr,password,db}
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
# 以下为常量(已对齐 Next.js),如需改动改 internal/consts/consts.go
# REDIS_INDEX_NAME=idx:biz
# REDIS_KEY_PREFIX=biz:
# REDIS_VECTOR_FIELD=vector

# ---- MCP (Log 工具 SSE) ----
# config.json: mcp_url
MCP_URL=http://localhost:3000/sse

# ---- Prometheus ----
# config.json: prometheus_url  (空则禁用 query_prometheus_alerts 工具)
PROMETHEUS_URL=http://127.0.0.1:9090

# ---- Log Topic (注入 chat system prompt,两者都非空才生效) ----
# config.json: log_topic_region / log_topic_id
LOG_TOPIC_REGION=
LOG_TOPIC_ID=

# ---- 文件上传目录 ----
# config.json: file_dir
FILE_DIR=./data/docs
